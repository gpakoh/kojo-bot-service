# Kojo Bot — Environment Configuration
# Do not commit real secrets. Use separate values for local/staging/production.

# === Required ===
BOT_TOKEN=<telegram-bot-token>
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>
QUART_SERVER_URL=http://<quart-host>:5000
INTEGRATION_SERVER_URL=http://<integration-host>:5000
BOT_ID_FOR_QUART=kojo
ADMIN_CHAT_ID=<telegram-id>

# === Optional — connections ===
REDIS_URL=redis://<host>:6379/0
KOJO_DATABASE_URL=
KOJO_REDIS_URL=

# === Optional — bot ===
ADMIN_IDS=
WELCOME_MESSAGE=Добро пожаловать!
BOT_INTERNAL_PORT=8080
RESET_PERSISTENCE=false

# === Optional — webhook (leave empty for polling) ===
WEBHOOK_PUBLIC_URL=
WEBHOOK_SECRET_TOKEN=

# === Optional — proxy ===
USE_PROXY=false
TG_PROXY_URL=

# === Optional — logging & observability ===
LOG_LEVEL=INFO
ENVIRONMENT=local
ENABLE_METRICS=true
ENABLE_TRACING=true
APP_VERSION=unknown
TENANT_BOT_ID=default
JAEGER_ENDPOINT=

# === Optional — database pool ===
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20
DB_COMMAND_TIMEOUT=10
DB_POOL_MAX_INACTIVE_TIME=300
DB_CONNECTION_TIMEOUT=30
DB_MAX_RETRY_ATTEMPTS=3
DB_RETRY_BASE_DELAY=1.0

# === Optional — cache ===
CACHE_DEFAULT_TTL=3600
CIRCUIT_FAILURE_THRESHOLD=5
CIRCUIT_RECOVERY_TIMEOUT=30

# === Optional — monitoring ===
SLOW_QUERY_THRESHOLD_MS=100
QUERY_MONITORING=true
LOG_ALL_QUERIES=false

# === Optional — delivery ===
WEBAPP_MAP_URL=
YANDEX_MAPS_API_KEY=
DEFAULT_WEIGHT_GRAMS=500
ORDER_ASSEMBLY_DAYS=2

# === Optional — proxy pool ===
PROXY_POOL=
PROXY_POOL_2=
PROXY_POOL_3=
PROXY_COOLDOWN_SECONDS=300
PROXY_HEALTH_CHECK_INTERVAL=60

# === Optional — backup ===
BACKUP_DIR=./backups
RETENTION_DAYS=14
