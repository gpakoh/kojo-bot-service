# Kojo Bot — Docker deployment variables
# Копировать в корень проекта: cp docker/.env.example ../.env
# Заполнить реальными значениями перед docker compose up
# Do not commit real secrets. Use separate values for local/staging/production.

# === Required ===
BOT_TOKEN=<telegram-bot-token>
DATABASE_URL=postgresql://<user>:<password>@RAG_kojo-db:5432/<db>
QUART_SERVER_URL=http://<quart-host>:5000
INTEGRATION_SERVER_URL=http://<integration-host>:5000
BOT_ID_FOR_QUART=kojo
ADMIN_CHAT_ID=<telegram-id>

# === Optional ===
ADMIN_IDS=
REDIS_URL=redis://<host>:6379/0
BOT_INTERNAL_PORT=8080
LOG_LEVEL=INFO
WEBHOOK_PUBLIC_URL=
WEBHOOK_SECRET_TOKEN=
TG_PROXY_URL=
USE_PROXY=false
