# Kojo Bot — Docker deployment variables
# Копировать в корень проекта:  cp docker/.env.example ../.env
# Заполнить реальными значениями перед docker compose up

BOT_TOKEN=your_telegram_bot_token_here
DATABASE_URL=postgresql://kojo_user:kojo_password@RAG_kojo-db:5432/kojo_db
QUART_SERVER_URL=http://RAG_quart-server:5000
INTEGRATION_SERVER_URL=http://integration-server:5000
BOT_ID_FOR_QUART=kojo
ADMIN_CHAT_ID=0
ADMIN_IDS=
REDIS_URL=redis://RAG_kojo-redis:6379/0
BOT_INTERNAL_PORT=8080
LOG_LEVEL=INFO
WEBHOOK_PUBLIC_URL=
WEBHOOK_SECRET_TOKEN=
TG_PROXY_URL=
USE_PROXY=false
